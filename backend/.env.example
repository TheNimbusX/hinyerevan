APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:5173
API_RATE_LIMIT=6000
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=
TRANSLATE_ENABLED=false
TRANSLATE_DRIVER=mymemory
TRANSLATE_SOURCE=hy
    TRANSLATE_MAX_API_CALLS=48
TRANSLATE_PARALLEL_BATCH=12
LIBRETRANSLATE_URL=https://libretranslate.com
LIBRETRANSLATE_API_KEY=

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hin-yerevan
DB_USERNAME=hin-yerevan
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_FEEDBACK_TO=info@hinyerevan.com

HINYEREVAN_LEGACY_ROOT=../hin-yerevan-backup-prod/hin-yerevan1
HINYEREVAN_PHOTOS_ORIGINAL=photos/o
HINYEREVAN_PHOTOS_LARGE=photos/x
HINYEREVAN_PHOTOS_THUMB=photos/192x192
HINYEREVAN_PHOTOS_USERS=photos/users
# Serve-time watermark for legacy photos. Leave EMPTY in production: legacy
# photos already have a watermark baked in, new uploads get one at upload time.
HINYEREVAN_WATERMARK=
# Watermark burned into NEW uploads (defaults to resources/watermark/logo.png).
HINYEREVAN_WATERMARK_UPLOAD=

# Optional: import legacy like counts from old DB (SSH tunnel to old server) or CSV.
# LEGACY_LIKES_DB_CONNECTION=legacy_likes
# LEGACY_LIKES_DB_HOST=127.0.0.1
# LEGACY_LIKES_DB_PORT=3310
# LEGACY_LIKES_DB_DATABASE=hin-yerevan
# LEGACY_LIKES_DB_USERNAME=hin-yerevan
# LEGACY_LIKES_DB_PASSWORD=

# ---- Social login (OAuth) ---------------------------------------------------
# Public URL of the site (no trailing slash). All OAuth callback URLs are built from it:
#   {OAUTH_REDIRECT_BASE}/api/auth/social/{provider}/callback
# VK ID, Google, Facebook, Instagram: require https:// and a domain name (not http://IP).
# Production/dev example: https://hinyerevan.ru (@ and www A → server IP, certbot).
# See deploy/HINYEREVAN-RU.md and deploy/SSL-AND-OAUTH.md
OAUTH_REDIRECT_BASE=http://127.0.0.1:8000
# Optional: socks5://127.0.0.1:1080 or http://user:pass@proxy:port
# Required on many VPS for Yandex (login.yandex.ru is blocked; oauth.yandex.ru works).
# Also helps if Google/Meta APIs time out from the datacenter.
OAUTH_PROXY=

# Google — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook — https://developers.facebook.com/apps (needed for ~366 legacy FB users)
# Callback: {OAUTH_REDIRECT_BASE}/api/auth/social/facebook/callback
# Page integration: deploy/FACEBOOK-PAGE-INTEGRATION.md
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_URL=https://www.facebook.com/HinYerevanCom/
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_APP_ID=
# JS SDK / Page Plugin on /facebook (usually = FACEBOOK_CLIENT_ID, not HinYerevanPage)
FACEBOOK_PLUGIN_APP_ID=
# App secret of FACEBOOK_APP_ID (HinYerevanPage Business app), for facebook:exchange-token
FACEBOOK_APP_SECRET=
# FACEBOOK_GRAPH_PROXY=   # only if Graph API needs a proxy; do not reuse OAUTH_PROXY on VPS
# Email that receives alerts from `facebook:refresh-token` when the Page token can't be refreshed
FACEBOOK_ALERT_EMAIL=
# Test page setup: deploy/FACEBOOK-TEST-PAGE.md — php artisan facebook:diagnose

# VK ID — https://id.vk.com (OAuth 2.1 + PKCE; only https redirect URLs)
# Trusted redirect: {OAUTH_REDIRECT_BASE}/api/auth/social/vkontakte/callback
# Base domain in VK app: your domain without https://
# VK_CLIENT_ID = «ID приложения» (число, напр. 54617594)
# VK_CLIENT_SECRET = «Защищённый ключ» (K83XmmL… — НЕ «Сервисный ключ доступа»)
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# Odnoklassniki — для входа на сайт достаточно VK ID (id.vk.com → Авторизация → «через Одноклассники»).
# Отдельные OK_CLIENT_* нужны только для legacy OAuth OK API (игры/виджеты), не для VK ID.
OK_CLIENT_ID=
OK_CLIENT_SECRET=
OK_CLIENT_PUBLIC=

# Yandex — https://oauth.yandex.com/client/new
# Callback: {OAUTH_REDIRECT_BASE}/api/auth/social/yandex/callback
# Scopes login:email + login:info are requested automatically.
# If login works in the browser but fails on the site, set OAUTH_PROXY (see above).
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# Instagram — Meta app (Instagram product). Often same Meta app as Facebook.
# Callback: {OAUTH_REDIRECT_BASE}/api/auth/social/instagram/callback
INSTAGRAM_OAUTH_ENABLED=false
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
