APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:5173
API_RATE_LIMIT=6000
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=
TRANSLATE_ENABLED=false
TRANSLATE_DRIVER=mymemory
TRANSLATE_SOURCE=hy
LIBRETRANSLATE_URL=https://libretranslate.com
LIBRETRANSLATE_API_KEY=

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hin-yerevan
DB_USERNAME=hin-yerevan
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_FEEDBACK_TO=info@hinyerevan.com

HINYEREVAN_LEGACY_ROOT=../hin-yerevan-backup-prod/hin-yerevan1
HINYEREVAN_PHOTOS_ORIGINAL=photos/o
HINYEREVAN_PHOTOS_LARGE=photos/x
HINYEREVAN_PHOTOS_THUMB=photos/192x192
HINYEREVAN_PHOTOS_USERS=photos/users
# Serve-time watermark for legacy photos. Leave EMPTY in production: legacy
# photos already have a watermark baked in, new uploads get one at upload time.
HINYEREVAN_WATERMARK=
# Watermark burned into NEW uploads (defaults to resources/watermark/logo.png).
HINYEREVAN_WATERMARK_UPLOAD=

# ---- Social login (OAuth) ------------------
# Base URL of THIS backend, used to build provider callback URLs.
OAUTH_REDIRECT_BASE=http://127.0.0.1:8000

# Google  -> https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Facebook -> https://developers.facebook.com/apps
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
# Yandex  -> https://oauth.yandex.com/client/new
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
# VK      -> https://vk.com/apps?act=manage
VK_CLIENT_ID=
VK_CLIENT_SECRET=
# Odnoklassniki -> https://ok.ru/devaccess  (needs id, secret AND public key)
OK_CLIENT_ID=
OK_CLIENT_SECRET=
OK_CLIENT_PUBLIC=
