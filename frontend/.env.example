# Base URL of the backend API.
VITE_API_URL=http://127.0.0.1:8000/api
# Public Google reCAPTCHA v2 site key (safe to expose; leave blank to disable).
VITE_RECAPTCHA_SITE_KEY=
# Yandex Maps JS API key (Before/After panoramas).
VITE_YANDEX_MAPS_KEY=
# Google Maps JS API key with Street View enabled (Before/After panoramas).
VITE_GOOGLE_MAPS_KEY=
